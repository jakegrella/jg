{
  "name": "jg",
  "version": "1.0.0",
  "description": "JG website",
  "type": "module",
  "scripts": {
    "build": "next build && tsc --project tsconfig.server.json",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation nodemon",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation nodemon",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation NODE_ENV=production node dist/server.js"
  },
  "dependencies": {
    "@payloadcms/db-vercel-postgres": "3.33.0",
    "@payloadcms/email-resend": "3.33.0",
    "@payloadcms/next": "3.33.0",
    "@payloadcms/richtext-lexical": "3.33.0",
    "@payloadcms/storage-uploadthing": "3.33.0",
    "@phosphor-icons/react": "^2.1.8",
    "@tailwindcss/postcss": "4.0.9",
    "@vercel/analytics": "1.5.0",
    "clsx": "2.1.1",
    "cross-env": "7.0.3",
    "express": "5.1.0",
    "graphql": "16.10.0",
    "next": "15.2.4",
    "payload": "3.33.0",
    "postcss": "8.5.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sharp": "0.32.6",
    "tailwindcss": "4.0.9",
    "zustand": "5.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@types/express": "5.0.2",
    "@types/node": "22.5.4",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "eslint": "9.16.0",
    "eslint-config-next": "15.1.5",
    "nodemon": "3.1.10",
    "prettier": "3.4.2",
    "tsx": "4.19.4",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  }
}
